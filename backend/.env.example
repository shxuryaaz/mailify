# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8000

# The one product decision left open (Part 4): "reply_worthy" | "high_priority_only"
DRAFT_MODE=reply_worthy
HIGH_PRIORITY_THRESHOLD=70
REDISTILL_THRESHOLD=5
ONBOARDING_SENT_SAMPLE=300

# ── Neon (Postgres) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Crypto (run: python -m app.scripts.gen_keys) ─────────────────────────────
FERNET_KEY=
JWT_SECRET=

# ── Google OAuth (sign-in + Gmail) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# ── Gmail Pub/Sub push ───────────────────────────────────────────────────────
# projects/<gcp-project>/topics/<topic>
GMAIL_PUBSUB_TOPIC=
# Shared secret appended to the push subscription URL as ?token=...
PUBSUB_VERIFICATION_TOKEN=

# ── Web Push (VAPID — from gen_keys) ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Cron auth (from gen_keys) ────────────────────────────────────────────────
CRON_SECRET=
